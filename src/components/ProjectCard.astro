---
// src/components/ProjectCard.astro
interface Props {
  title: string;
  description: string;
  image: string;
  technologies: string[];
  slug: string;
  liveUrl?: string;
  githubUrl?: string;
}

const { title, description, image, technologies, slug, liveUrl } = Astro.props;
---

<article class="group relative flex flex-col bg-bg-secondary border border-gray-500 hover:border-accent shadow-lg hover:shadow-xl hover:shadow-accent/5 transition-all duration-500 overflow-hidden">
  
  {/* IMAGEN — enlace principal */}
  <a 
    href={`/projects/${slug}`} 
    class="block overflow-hidden focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-black"
  >
    <div class="aspect-video bg-black">
      <img 
        src={image} 
        alt={title} 
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  </a>

  <div class="p-6 flex flex-col flex-grow border-t border-gray-600 group-hover:border-accent transition-colors duration-500">
    
    {/* TÍTULO — enlace principal */}
    <h3 class="text-2xl font-bold text-text-primary mb-2 group-hover:text-accent transition-colors">
      <a href={`/projects/${slug}`} class="hover:underline">
        {title}
      </a>
    </h3>
    
    <p class="text-text-secondary text-sm leading-relaxed mb-4 flex-grow">
      {description}
    </p>

    {/* Tech Stack */}
    <div class="flex flex-wrap gap-2 mb-4">
      {technologies.map((tech) => (
        <span class="text-sm bg-bg-secondary border border-gray-600 text-text-secondary px-3 py-1 rounded-full">
          {tech}
        </span>
      ))}
    </div>

    {/* Footer */}
    {/* CAMBIO: Quitado justify-between, añadido gap-4 para que estén juntos a la izquierda */}
    <div class="flex flex-wrap gap-4 mt-auto pt-4 border-t border-gray-600">
      
      {/* CAMBIO: Ahora es <a>, tiene hover local y flex para alinear icono */}
      <a 
        href={`/projects/${slug}`}
        class="text-sm font-bold text-text-primary hover:text-accent transition-colors uppercase tracking-wide flex items-center gap-2"
      >
        Ver Proyecto
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="7" y1="17" x2="17" y2="7"></line>
          <polyline points="7 7 17 7 17 17"></polyline>
        </svg>
      </a>

      {/* Demo externo */}
      {liveUrl && (
        <a 
          href={liveUrl} 
          target="_blank" 
          rel="noopener" 
          class="text-sm font-bold text-text-secondary hover:text-accent transition-colors uppercase tracking-wide"
        >
          Demo
        </a>
      )}
    </div>
  </div>
</article>