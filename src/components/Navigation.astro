---
// src/components/Navigation.astro
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-sm border-b border-gray-600">
  <div class="flex justify-between items-center h-16 px-6 md:px-24 lg:px-32">
    
    <!-- Logo -->
    <a href="/" class="hover:opacity-80 transition-opacity">
      <img 
        src="/images/Logo IA.png" 
        alt="Isabel Abad Logo" 
        class="h-8 w-auto" 
        width="32" 
        height="32"
      />
    </a>
    
    <!-- Menú desktop -->
    <div class="hidden md:flex gap-8 items-center">
      <a href="/" class="nav-link text-text-primary hover:text-accent transition-colors">INICIO</a>
      <a href="/#projects" class="nav-link text-text-primary hover:text-accent transition-colors">PROYECTOS</a>
      <a href="/#about" class="nav-link text-text-primary hover:text-accent transition-colors">SOBRE MÍ</a>
      <a href="/cv" class="nav-link text-text-primary hover:text-accent transition-colors">CV</a>
      <a href="/#contact" class="nav-link text-text-primary hover:text-accent transition-colors">CONTACTO</a>
    </div>
    
    <!-- Botón menú móvil -->
    <button 
      id="menu-btn" 
      class="md:hidden flex flex-col justify-center items-center gap-1 text-text-primary hover:text-accent"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-haspopup="true"
    >
      <span class="hamburger-line w-6 h-0.5 bg-current transition-all duration-300 origin-center"></span>
      <span class="hamburger-line w-6 h-0.5 bg-current transition-all duration-300 origin-center"></span>
      <span class="hamburger-line w-6 h-0.5 bg-current transition-all duration-300 origin-center"></span>
    </button>
  </div>

  <!-- Menú móvil -->
  <div 
    id="mobile-menu" 
    class="hidden md:hidden absolute top-16 left-0 right-0 px-6 pb-6 bg-background border-b border-gray-800"
    aria-hidden="true"
  >
    <div class="flex flex-col gap-4">
      <a href="/" class="nav-link text-text-primary hover:text-accent transition-colors">INICIO</a>
      <a href="/#projects" class="nav-link text-text-primary hover:text-accent transition-colors">PROYECTOS</a>
      <a href="/#about" class="nav-link text-text-primary hover:text-accent transition-colors">SOBRE MÍ</a>
      <a href="/cv" class="nav-link text-text-primary hover:text-accent transition-colors">CV</a>
      <a href="/#contact" class="nav-link text-text-primary hover:text-accent transition-colors">CONTACTO</a>
    </div>
  </div>
</nav>

<!-- Espaciador -->
<div class="h-16"></div>

<style>
  .nav-link.active {
    color: #9eff00;
    border-bottom: 2px solid #9eff00;
    padding-bottom: 4px;
  }

  #menu-btn.menu-open .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translateY(0.35rem);
  }
  #menu-btn.menu-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  #menu-btn.menu-open .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translateY(-0.35rem);
  }
</style>

<script>
  let observer: IntersectionObserver | null = null;
  let scrollHandler: (() => void) | null = null;

  function initNavigation() {
    const btn = document.getElementById("menu-btn") as HTMLButtonElement | null;
    const menu = document.getElementById("mobile-menu") as HTMLElement | null;

    if (btn && menu && !btn.dataset.initialized) {
      btn.dataset.initialized = "true";

      const closeMenu = () => {
        menu.classList.add("hidden");
        btn.classList.remove("menu-open");
        btn.setAttribute("aria-expanded", "false");
        btn.setAttribute("aria-label", "Abrir menú");
        menu.setAttribute("aria-hidden", "true");
        btn.focus();
      };

      const openMenu = () => {
        menu.classList.remove("hidden");
        btn.classList.add("menu-open");
        btn.setAttribute("aria-expanded", "true");
        btn.setAttribute("aria-label", "Cerrar menú");
        menu.setAttribute("aria-hidden", "false");
        
        const firstLink = menu.querySelector("a") as HTMLAnchorElement | null;
        firstLink?.focus();
      };

      btn.addEventListener("click", () => {
        const isExpanded = !menu.classList.contains("hidden");
        if (isExpanded) {
          closeMenu();
        } else {
          openMenu();
        }
      });

      menu.querySelectorAll("a").forEach(link => {
        link.addEventListener("click", closeMenu);
      });
    }

    // --- Lógica de navegación activa ---
    const setActive = (selector: string) => {
      document.querySelectorAll('.nav-link').forEach(link => {
        link.classList.remove('active');
      });
      document.querySelectorAll(selector).forEach(link => {
        link.classList.add('active');
      });
    };

    if (observer) observer.disconnect();
    if (scrollHandler) window.removeEventListener('scroll', scrollHandler);

    const path = window.location.pathname;
    const cleanPath = path === '/' ? '/' : path.replace(/\/$/, '');

    if (cleanPath === '/cv') {
      setActive('.nav-link[href="/cv"]');
      return;
    }

    if (cleanPath.startsWith('/projects')) {
      setActive('.nav-link[href="/#projects"]');
      return;
    }

    if (cleanPath !== '/') return;

    const sections = document.querySelectorAll<HTMLElement>('section[id]');

    observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && window.scrollY >= 100) {
          const id = entry.target.getAttribute('id');
          if (id) {
            setActive(`.nav-link[href="/#${id}"]`);
          }
        }
      });
    }, {
      rootMargin: '-30% 0px -60% 0px',
      threshold: 0
    });

    sections.forEach(section => observer?.observe(section));

    scrollHandler = () => {
      if (window.scrollY < 100) {
        setActive('.nav-link[href="/"]');
      }
    };

    window.addEventListener('scroll', scrollHandler, { passive: true });
  }

  // Inicialización
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initNavigation);
  } else {
    initNavigation();
  }

  document.addEventListener("astro:page-load", initNavigation);

  // ✅ LISTENER GLOBAL ROBUSTO + FOCUS TRAP (Versión definitiva)
  if (!document.body.dataset.navKeyListener) {
    document.body.dataset.navKeyListener = "true";
    
    document.addEventListener('keydown', (e) => {
      const menu = document.getElementById("mobile-menu");
      const btn = document.getElementById("menu-btn");

      // Si el menú no existe o está cerrado, no hacemos nada
      if (!menu || !btn || menu.classList.contains('hidden')) return;

      // 1. Cerrar con Escape
      if (e.key === 'Escape') {
        menu.classList.add("hidden");
        btn.classList.remove("menu-open");
        btn.setAttribute("aria-expanded", "false");
        btn.setAttribute("aria-label", "Abrir menú");
        menu.setAttribute("aria-hidden", "true");
        btn.focus();
        return;
      }

      // 2. Focus Trap (Tab cycling) - La única mejora real incorporada
      if (e.key === 'Tab') {
        const focusableElements = menu.querySelectorAll("a");
        const firstElement = focusableElements[0];
        const lastElement = focusableElements[focusableElements.length - 1];

        if (e.shiftKey && document.activeElement === firstElement) {
          e.preventDefault();
          lastElement.focus();
        } else if (!e.shiftKey && document.activeElement === lastElement) {
          e.preventDefault();
          firstElement.focus();
        }
      }
    });
  }
</script>