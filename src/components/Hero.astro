---
// src/components/Hero.astro
---

<!-- Hero con padding unificado (px-6 md:px-24 lg:px-32) para alinear con secciones -->
<section id="hero" class="min-h-screen flex flex-col justify-center px-6 md:px-24 lg:px-32 relative overflow-hidden">
  <div class="z-10">
    <p class="text-accent text-h2-label uppercase tracking-widest mb-4 font-bold">
      Frontend Developer
    </p>

    <h1 class="text-hero-mobile md:text-hero-desktop font-normal text-text-primary tracking-tighter">
      Isabel Abad
    </h1>

    <p class="mt-6 text-xl md:text-2xl text-text-secondary max-w-2xl leading-relaxed">
      Desarrollo web orientado a producto y basado en datos
    </p>

    <!-- Botones alineados -->
    <div class="flex flex-wrap gap-4 mt-10">
      <a href="#projects" class="px-6 py-3 bg-accent text-text-dark font-bold rounded-sm hover:bg-white transition-transition-all duration-300">
        Ver Proyectos
      </a>
      <a href="#contact" class="px-6 py-3 border border-accent text-accent font-bold rounded-sm hover:bg-accent hover:text-black transition-all duration-300">
        Contacto
      </a>
    </div>
  </div>
</section>
