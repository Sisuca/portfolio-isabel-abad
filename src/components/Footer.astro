---
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

// ORDEN: Alfabético por Título (A-Z)
const featuredProjects = allProjects
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .slice(0, 2);

const currentYear = new Date().getFullYear();
---

<footer class="bg-bg-secondary border-t border-gray-800 mt-14 py-8 px-6 md:px-12">
  <div class="max-w-6xl mx-auto space-y-12">
    
    <!-- FEATURED PROJECTS -->
    <div>
      <h4 class="text-sm font-bold text-accent uppercase tracking-widest mb-8">
        Featured Projects
      </h4>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
        {featuredProjects.map((project) => (
          <div class="flex flex-col gap-2">
            <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
              <a href={`/projects/${project.slug}`} class="text-text-primary font-bold hover:text-accent transition-colors">
                {project.data.title}
              </a>
              
              <div class="flex gap-3 text-xs text-text-secondary font-mono">
                {project.data.liveUrl && (
                  <a href={project.data.liveUrl} target="_blank" class="hover:text-accent">[Demo]</a>
                )}
                {project.data.githubUrl && (
                  <a href={project.data.githubUrl} target="_blank" class="hover:text-accent">[GitHub]</a>
                )}
              </div>
            </div>
            
            <p class="text-text-secondary text-sm max-w-md">
              {project.data.description}
            </p>
          </div>
        ))}
      </div>
    </div>

    <!-- NAVEGACIÓN Y COPYRIGHT -->
    <div class="border-t border-gray-800 pt-12 flex flex-col items-center gap-8">
      
      <nav class="flex items-center justify-center gap-4 text-sm font-bold text-text-primary uppercase tracking-wide">
        <a href="/#about" class="hover:text-accent transition-colors">Sobre mí</a>
        <span class="text-accent">•</span>
        <a href="/cv" class="hover:text-accent transition-colors">CV</a>
        <span class="text-accent">•</span>
        <a href="/#contact" class="hover:text-accent transition-colors">Contacto</a>
      </nav>

      <p class="text-text-secondary text-sm text-center">
        ©{currentYear} Isabel Abad • Desarrollo web orientado a producto y basado en datos

      </p>

      <div class="flex gap-6">
        <a href="https://github.com/Sisuca" target="_blank" class="text-text-primary hover:text-accent transition-colors" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/abadisabel" target="_blank" class="text-text-primary hover:text-accent transition-colors" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</footer>
