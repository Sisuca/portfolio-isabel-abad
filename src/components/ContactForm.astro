---
const action = "/api/contact";
---

<form id="contact-form" action={action} method="POST" class="space-y-6 max-w-xl mx-auto">
  {/* Campo Nombre */}
  <div class="flex flex-col gap-2">
    <label for="name" class="text-sm text-text-primary uppercase tracking-wide">Nombre</label>
    <input 
      id="name" name="name" type="text" required maxlength="100"
      autocomplete="name"
      class="bg-transparent border-b border-gray-400 py-3 px-1 text-text-primary focus:outline-none focus:border-accent transition-colors"
    />
  </div>

  {/* Campo Email */}
  <div class="flex flex-col gap-2">
    <label for="email" class="text-sm text-text-primary uppercase tracking-wide">Email</label>
    <input 
      id="email" name="email" type="email" required maxlength="100"
      autocomplete="email"
      class="bg-transparent border-b border-gray-400 py-3 px-1 text-text-primary focus:outline-none focus:border-accent transition-colors"
    />
  </div>

  {/* Campo Mensaje */}
  <div class="flex flex-col gap-2">
    <label for="message" class="text-sm text-text-primary uppercase tracking-wide">Mensaje</label>
    <textarea 
      id="message" name="message" rows={4} required maxlength="5000"
      autocomplete="off"
      class="bg-transparent border-b border-gray-400 py-3 px-1 text-text-primary focus:outline-none focus:border-accent transition-colors resize-none"
    ></textarea>
  </div>

  {/* Botón Enviar */}
  <div class="pt-4 flex flex-col items-center gap-4">
    <button 
      type="submit"
      class="w-full py-4 font-bold bg-accent text-text-dark hover:bg-white transition-all duration-300 flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-wait"
    >
      Enviar mensaje
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
    </button>
    {/* Accesibilidad: role y aria-live declarados estáticamente */}
    <p id="form-status" class="text-sm h-4" aria-live="polite" role="status"></p>
  </div>
</form>

<script>
  const initContactForm = () => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('form-status') as HTMLElement | null;
    const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    if (!form || !btn || form.dataset.initialized) return;
    form.dataset.initialized = "true";

    const originalBtn = btn.innerHTML;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (btn.disabled) return;

      btn.innerHTML = 'Enviando... <span class="animate-pulse">⏳</span>';
      btn.disabled = true;

      if (status) {
        status.textContent = '';
        status.className = 'text-sm h-4';
        status.removeAttribute('tabindex');
      }

      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 12000);

      try {
        const formData = new FormData(form);

        const payload = {
          name: String(formData.get('name') || ''),
          email: String(formData.get('email') || ''),
          message: String(formData.get('message') || '')
        };

        const response = await fetch('/api/contact', {
          method: 'POST',
          body: JSON.stringify(payload),
          headers: { 'Content-Type': 'application/json' },
          signal: controller.signal
        });

        let result;
        try {
          result = await response.json();
        } catch {
          throw new Error('Respuesta inválida del servidor');
        }

        if (!response.ok) {
          throw new Error(result.error || 'Error en el servidor');
        }

        if (status) {
          status.textContent = '✅ Mensaje enviado correctamente.';
          status.className = 'text-sm text-accent'; // Restaurado tu clase de éxito
        }

        form.reset();

      } catch (error: any) {
        let message = '❌ Error al enviar. Intenta de nuevo.';

        if (error.name === 'AbortError') {
          message = '⏱️ Tiempo de espera agotado.';
        } else if (error.message) {
          message = `❌ ${error.message}`;
        }

        if (status) {
          status.textContent = message;
          status.className = 'text-sm text-red-500';
          status.setAttribute('tabindex', '-1');
          status.focus();
        }

      } finally {
        clearTimeout(timeoutId);
        btn.innerHTML = originalBtn;
        btn.disabled = false;
      }
    });
  };

  // Eventos Astro para SPA
  document.addEventListener('astro:page-load', () => {
    requestAnimationFrame(initContactForm);
  });

  document.addEventListener('DOMContentLoaded', initContactForm);
</script>