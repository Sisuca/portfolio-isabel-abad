---

<Layout title="CV | Isabel Abad">
  <main class="min-h-screen pt-4 pb-20 px-6 md:px-24 lg:px-32">
    <h4
      class="text-h2-label text-accent font-bold uppercase tracking-widest mb-12"
    >
      CV
    </h4>

    <a
      href="/#about"
      class="text-text-secondary hover:text-accent text-sm mb-8 inline-block"
    >
      ← Volver a Sobre Mí
    </a>

    <div class="flex flex-col md:flex-row gap-12 md:gap-16">
      {/* COLUMNA IZQUIERDA */}
      <aside class="w-full md:w-[30%] flex flex-col gap-8">
        <div
          class="w-36 h-36 rounded-full overflow-hidden border-2 border-accent mx-auto md:mx-0 flex-shrink-0"
        >
          <img
            src="/images/isabel-abad.jpg"
            alt="Isabel Abad"
            class="w-full h-full object-cover"
          />
        </div>

        <div class="sticky top-24 self-start flex flex-col gap-8">
          <div class="text-center md:text-left">
            <h1 class="text-3xl font-bold text-text-primary mb-1">
              Isabel Abad
            </h1>
            <p class="text-lg text-accent font-medium mb-3">
              Frontend Developer
            </p>
            <p class="text-base text-text-secondary leading-relaxed mb-1">
              Desarrolladora Frontend con experiencia en marketing digital y
              gestión de proyectos web.
            </p>
            <p class="text-base text-text-secondary leading-relaxed mb-1">
              Especializada en desarrollo web orientado a producto, interfaces
              intuitivas y análisis de datos.
            </p>
            <p class="text-base text-text-secondary leading-relaxed mb-1">
              Experiencia transformando necesidades de negocio en soluciones
              digitales eficientes y coordinando equipos multidisciplinares.
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mt-1">
            <a
              href="/Isabel_Abad_CV.pdf"
              download
              class="sm:flex-1 px-6 py-3 bg-accent text-text-dark font-bold rounded-sm hover:bg-white transition-transition-all duration-300 text-center text-sm whitespace-nowrap"
            >
              Descargar CV (PDF)
            </a>
            <a
              href="/#projects"
              class="sm:flex-1 px-6 py-3 border border-accent text-accent font-bold rounded-sm hover:bg-accent hover:text-black transition-all duration-300 text-center text-sm whitespace-nowrap"
            >
              Ver Proyectos
            </a>
          </div>

          {/* Tech Stack */}
          <div class="mt-4">
            <h3
              class="text-sm font-bold text-accent uppercase tracking-widest mb-2 border-b border-gray-800 pb-2"
            >
              Stack Tecnológico
            </h3>

            <div class="mb-8">
              <h4
                class="text-text-primary text-base font-semibold capitalize tracking-wide mb-3"
              >
                Frontend Developer
              </h4>
              <div class="flex flex-wrap gap-2">
                {
                  skills.frontend.map((skill) => (
                    <div class="flex items-center gap-1.5 bg-bg-secondary px-3 py-1 border border-gray-700 rounded-full hover:border-accent transition-colors">
                      <svg
                        class="w-5 h-5 text-accent"
                        viewBox={skill.svg.viewBox}
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <Fragment set:html={skill.svg.path} />
                      </svg>
                      <span class="text-sm font-medium text-text-primary">
                        {skill.name}
                      </span>
                    </div>
                  ))
                }
              </div>
            </div>

            <div>
              <h4
                class="text-text-primary text-base font-semibold capitalize tracking-wide mb-3"
              >
                Data Analyst
              </h4>
              <div class="flex flex-wrap gap-2">
                {
                  skills.analyst.map((skill) => (
                    <div class="flex items-center gap-1.5 bg-bg-secondary px-3 py-1 border border-gray-700 rounded-full hover:border-accent transition-colors">
                      <svg
                        class="w-5 h-5 text-accent"
                        viewBox={skill.svg.viewBox}
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <Fragment set:html={skill.svg.path} />
                      </svg>
                      <span class="text-sm font-medium text-text-primary">
                        {skill.name}
                      </span>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </aside>

      {/* COLUMNA DERECHA */}
      <div class="w-full md:w-[70%] flex flex-col gap-12">
        <section>
          <h2
            class="text-sm font-bold text-accent uppercase tracking-widest mb-8 border-b border-gray-800 pb-4"
          >
            Experiencia Profesional
          </h2>

          <div class="flex flex-col gap-8">
            {
              experienceData.map((exp) => (
                <div class="flex flex-col gap-1">
                  <div class="flex justify-between items-baseline">
                    <h3 class="text-xl font-bold text-text-primary">
                      {exp.role}
                    </h3>
                    <span class="text-sm font-mono text-accent flex-shrink-0 ml-4">
                      {exp.period}
                    </span>
                  </div>
                  <p class="text-md text-text-secondary mb-2">{exp.company}</p>
                  <p class="text-lg text-text-secondary leading-relaxed mb-2">
                    {exp.description}
                  </p>

                  {exp.bullets && (
                    <ul class="list-disc pl-5 marker:text-accent text-base text-text-secondary leading-relaxed space-y-1 mt-1">
                      {exp.bullets.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  )}
                </div>
              ))
            }
          </div>
        </section>

        <section>
          <h2
            class="text-sm font-bold text-accent uppercase tracking-widest mb-8 border-b border-gray-800 pb-4"
          >
            Certificados
          </h2>

          <div class="flex flex-col gap-8">
            {
              certificatesData.map((cert) => (
                <div class="flex flex-col gap-1">
                  <div class="flex justify-between items-baseline">
                    <h3 class="text-lg font-bold text-text-primary">
                      {cert.name}
                    </h3>
                    <span class="text-sm font-mono text-accent flex-shrink-0 ml-4">
                      {cert.year}
                    </span>
                  </div>
                  <p class="text-md text-text-secondary mb-2">{cert.issuer}</p>

                  {/* WRAPPER DE ENLACES: Muestra el correcto según el dispositivo */}
                  <div class="mt-2 flex items-center gap-2">
                    {/* Enlace para ESCRITORIO (Visible en md y superiores) */}
                    <a
                      href={cert.link}
                      class="hidden md:inline-flex text-sm font-bold text-accent hover:text-white transition-colors items-center gap-1.5 group"
                    >
                      <span>Ver Certificado</span>
                      <Fragment set:html={certLinkIcon} />
                    </a>

                    {/* Enlace para MÓVIL (Oculto en md y superiores) */}
                    <a
                      href={cert.link + '.pdf'}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="md:hidden inline-flex text-sm font-bold text-accent hover:text-white transition-colors items-center gap-1.5 group"
                    >
                      <span>Ver Certificado</span>
                      <Fragment set:html={certLinkIcon} />
                    </a>
                  </div>
                </div>
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>