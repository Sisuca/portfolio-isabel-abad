---
// src/pages/certificados/[slug].astro
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  // Lista de PDFs (sin .pdf al final)
  const certs = [
    'javascript-fundamentals-2025',
    'javascript-dom-manipulation-2025',
    'responsive-design-mobile-first-2025',
    'css-architecture-2025',
    'tailwind-css-2025',
    'design-systems-fundamentals-2025',
    'power-bi-2025',
    'advanced-excel-for-data-analysis-2025',
    'data-analysis-professional-foundations-2025'
  ];
  
  return certs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

// Ruta a la carpeta PUBLICA (plural)
const pdfUrl = `/certificados/${slug}.pdf`;
---

<Layout title="Certificado | Isabel Abad">
  <main class="min-h-screen pt-4 pb-20 px-6 md:px-24 lg:px-32">
    
    <h4 class="text-h2-label text-accent font-bold uppercase tracking-widest mb-6">
      Certificado
    </h4>

    <a href="/cv" class="text-text-secondary hover:text-accent text-sm inline-block mb-8">
      ← Volver al CV
    </a>

    <div class="w-full h-[85vh] border border-gray-800 bg-bg-secondary rounded-sm overflow-hidden">
      <object 
        data={pdfUrl} 
        type="application/pdf" 
        width="100%" 
        height="100%"
        class="w-full h-full"
      >
        <p class="p-8 text-text-secondary text-center">
          Tu navegador no puede mostrar el PDF. 
          <a href={pdfUrl} download class="text-accent hover:underline">Descárgalo aquí</a>.
        </p>
      </object>
    </div>

  </main>
</Layout>