---
// src/pages/certificado/[slug].astro
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  // Definimos los slugs basados en tus archivos PDF reales
  const certs = [
    { slug: 'javascript-fundamentals-2025' },
    { slug: 'javascript-dom-manipulation-2025' },
    { slug: 'responsive-design-mobile-first-2025' },
    { slug: 'css-architecture-2025' },
    { slug: 'tailwind-css-2025' },
    { slug: 'design-systems-fundamentals-2025' },
    { slug: 'power-bi-2025' },
    { slug: 'advanced-excel-for-data-analysis-2025' },
    { slug: 'data-analysis-professional-foundations-2025' }
  ];
  
  return certs.map(cert => ({
    params: { slug: cert.slug },
  }));
}

const { slug } = Astro.params;
// Ruta al archivo PDF real en la carpeta public
const pdfUrl = `/certificates/${slug}.pdf`;
---

<Layout title="Certificado | Isabel Abad">
  <main class="min-h-screen pt-4 pb-20 px-6 md:px-24 lg:px-32">
    
    <h4 class="text-h2-label text-accent font-bold uppercase tracking-widest mb-6">
      Certificado
    </h4>

    <!-- Botón de volver destacado -->
    <a 
        href="/cv" 
        class="inline-flex items-center gap-2 text-text-secondary hover:text-accent text-sm mb-8 group"
    >
      <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Volver al CV
    </a>

    <div class="w-full h-[85vh] border border-gray-800 bg-bg-secondary rounded-sm overflow-hidden">
      <!-- ... objeto PDF ... -->
    </div>

  </main>
</Layout>